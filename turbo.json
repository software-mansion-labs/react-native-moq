{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".nvmrc", ".yarnrc.yml"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "prepare": {
      "dependsOn": ["^prepare"],
      "inputs": ["src/**", "package.json", "tsconfig*.json"],
      "outputs": ["lib/**"]
    },
    "typecheck": {
      "dependsOn": ["^prepare"],
      "inputs": ["src/**", "package.json", "tsconfig*.json"],
      "outputs": []
    },
    "build:android": {
      "env": ["ANDROID_HOME", "ORG_GRADLE_PROJECT_newArchEnabled"],
      "inputs": [
        "packages/react-native-moq/package.json",
        "packages/react-native-moq/android",
        "!packages/react-native-moq/android/build",
        "packages/react-native-moq/src/**",
        "example/package.json",
        "example/android",
        "!example/android/.gradle",
        "!example/android/build",
        "!example/android/app/build"
      ],
      "outputs": []
    },
    "build:ios": {
      "env": [
        "RCT_NEW_ARCH_ENABLED",
        "RCT_REMOVE_LEGACY_ARCH",
        "RCT_USE_RN_DEP",
        "RCT_USE_PREBUILT_RNCORE"
      ],
      "inputs": [
        "packages/react-native-moq/package.json",
        "packages/react-native-moq/*.podspec",
        "packages/react-native-moq/ios",
        "packages/react-native-moq/src/**",
        "example/package.json",
        "example/ios",
        "!example/ios/build",
        "!example/ios/Pods"
      ],
      "outputs": []
    }
  }
}
